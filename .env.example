# Database — Supabase poolers (Settings > Database > Connection string)
# Transaction pooler (app/runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (used by Prisma migrations)
DIRECT_URL="postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# API
API_PORT=4000
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Supabase
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""            # Project Settings > API > JWT Secret (verifies access tokens)
SUPABASE_PHOTOS_BUCKET="boat-photos"
SUPABASE_DOCUMENTS_BUCKET="boat-documents"
SUPABASE_EXPERIENCE_PHOTOS_BUCKET="experience-photos"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Apps
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"

# Seed (optional override for the requirements JSON path)
# ONBOARDING_SEED_FILE="/absolute/path/to/seahub_boat_listing_requirements_seed.json"
