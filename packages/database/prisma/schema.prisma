// GetYourBoat — Prisma schema
// Postgres (Supabase). Run `pnpm db:generate` after changes.
//
// Boat onboarding lookup/config tables are populated by the seed script from
// `seahub_boat_listing_requirements_seed.json` (single source of truth). Never
// hardcode onboarding fields — read them from these tables at runtime.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/* ================================ Enums ================================ */

enum UserRole {
  CUSTOMER
  CAPTAIN
  ADMIN
}

enum ProfileRole {
  OWNER
  ADMIN
  CUSTOMER
}

enum BoatStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  REJECTED
  SUSPENDED
}

enum ApprovalType {
  INSTANT
  MANUAL
}

enum OnboardingStep {
  LISTING_MODEL
  BOAT_TYPE_FEATURES
  AMENITIES
  LOCATION
  DESCRIPTION_RULES
  PHOTOS
  PRICING
  DOCUMENTS
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExtraPricingType {
  PER_BOOKING
  PER_PERSON
  PER_DAY
  PER_HOUR
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum MessageSenderType {
  CUSTOMER
  CAPTAIN
}

enum ExperienceStatus {
  DRAFT
  PENDING_REVIEW
  CHANGES_REQUESTED
  APPROVED
  ACTIVE
  PAUSED
  REJECTED
}

enum ExperienceCategory {
  BOAT_TOUR
  WATER_SPORTS
  FISHING
  DIVING_SNORKELING
  SUNSET_CRUISE
  PRIVATE_CHARTER_EXPERIENCE
  WORKSHOP_CLASS
  OTHER
}

enum ExperienceStep {
  CATEGORY
  TITLE_DESCRIPTION
  INCLUDED_INFO
  LOGISTICS
  PRICING
  CANCELLATION
  MEDIA
}

enum ExperiencePricingType {
  PER_PERSON
  PER_GROUP
}

enum CancellationPolicyType {
  FREE_24H
  FREE_48H
  NON_REFUNDABLE
  CUSTOM
}

enum DataSource {
  MANUAL
  EXTERNAL_API
}

enum BrandModelRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BoatBrandCategory {
  MOTORYACHT
  SAILBOAT_CATAMARAN
  GULET
  RIB
}

enum CabinType {
  SINGLE_CABIN
  DOUBLE_CABIN
  TWIN_CABIN
  BUNK_BED
  THREE_PLUS_BERTHS
  SALOON
  SHARED_BATHROOM
}

enum WcType {
  EXTERNAL
  EN_SUITE
}

enum EngineType {
  INBOARD
  OUTBOARD
  STERN_DRIVE
  JET_DRIVE
  ELECTRIC
  SAIL_NO_ENGINE
}

/* ===================== Captain profiles (auth + boats) ================= */
// Standalone captain accounts — email/password auth via apps/api JWT.

model Profile {
  id           String      @id @default(uuid()) @db.Uuid
  email        String?     @unique
  passwordHash String?
  fullName     String?
  phone        String?
  companyName  String?
  avatarUrl    String?
  address      String?
  language     String?     @default("tr")
  isVerified   Boolean     @default(true)
  role         ProfileRole @default(OWNER)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  boats            Boat[]         @relation("BoatOwner")
  reviewedBoats    Boat[]         @relation("BoatReviewer")
  reviewedDocs     BoatDocument[] @relation("DocumentReviewer")
  refreshTokens    RefreshToken[]
  captainConversations Conversation[] @relation("ConversationCaptain")
  experiences      Experience[]
  brandModelRequests BrandModelRequest[]

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String   @db.Uuid
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

/* ============================ Config / Lookups ========================= */
// All rows below are seeded from the requirements JSON (single source of truth).

/// A SEAHUB "package" the field set is scoped to (e.g. seahub_hourly).
model OnboardingPackage {
  id         String                     @id @default(cuid())
  key        String                     @unique
  label      String
  inclusions OnboardingFieldInclusion[]

  @@map("onboarding_packages")
}

/// Logical section / wizard grouping a field belongs to.
model OnboardingSection {
  id            String                      @id @default(cuid())
  key           String                      @unique
  label         String
  sourceSection String?
  sortOrder     Int                         @default(0)
  fields        OnboardingFieldDefinition[]

  @@map("onboarding_sections")
}

/// Raw catalog of every requirement row from the JSON (audit + provenance).
model OnboardingFieldDefinition {
  id                 String                     @id @default(cuid())
  key                String                     @unique
  label              String
  type               String
  sectionKey         String
  section            OnboardingSection          @relation(fields: [sectionKey], references: [key])
  sourceSection      String?
  sortOrder          Int                        @default(0)
  sourceRow          Int?
  canBeExtra         Boolean                    @default(false)
  amenityCategoryKey String?
  inclusions         OnboardingFieldInclusion[]

  @@index([type])
  @@index([sectionKey])
  @@map("onboarding_field_definitions")
}

/// Whether a given field is included in a given package (+ optional note).
model OnboardingFieldInclusion {
  id         String                    @id @default(cuid())
  fieldId    String
  field      OnboardingFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  packageKey String
  package    OnboardingPackage         @relation(fields: [packageKey], references: [key])
  included   Boolean                   @default(false)
  note       String?

  @@unique([fieldId, packageKey])
  @@map("onboarding_field_inclusions")
}

/// Amenity categories (navigation, kitchen_equipment, ...). Derived from JSON.
model AmenityCategory {
  id        String    @id @default(cuid())
  key       String    @unique
  label     String
  sortOrder Int       @default(0)
  amenities Amenity[]

  @@map("amenity_categories")
}

/// Individual amenities. Derived from `type = amenity` rows in the JSON.
model Amenity {
  id         String          @id @default(cuid())
  key        String          @unique
  label      String
  categoryId String
  category   AmenityCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  canBeExtra Boolean         @default(false)
  sortOrder  Int             @default(0)

  boats BoatAmenity[]

  @@index([categoryId])
  @@map("amenities")
}

/// Technical feature groups (boat identity, cabins, bathrooms, crew). From JSON sections.
model FeatureGroup {
  id            String              @id @default(cuid())
  key           String              @unique
  label         String
  sourceSection String?
  sortOrder     Int                 @default(0)
  features      FeatureDefinition[]

  @@map("feature_groups")
}

/// Technical feature fields. Derived from `type = feature`/`crew_option` rows.
model FeatureDefinition {
  id        String       @id @default(cuid())
  key       String       @unique
  label     String
  groupKey  String
  group     FeatureGroup @relation(fields: [groupKey], references: [key], onDelete: Cascade)
  sortOrder Int          @default(0)

  values BoatFeatureValue[]

  @@index([groupKey])
  @@map("feature_definitions")
}

/// Document types a captain must/can upload. Derived from `type = document` rows.
model DocumentType {
  id        String         @id @default(cuid())
  key       String         @unique
  label     String
  required  Boolean        @default(false)
  sortOrder Int            @default(0)
  documents BoatDocument[]

  @@map("document_types")
}

/// Boat type options (motoryacht, sailboat, ...). Seeded from companion config.
model BoatTypeOption {
  id        String @id @default(cuid())
  key       String @unique
  label     String
  sortOrder Int    @default(0)
  boats     Boat[]

  @@map("boat_type_options")
}

/// Listing / rental models (hourly, daily, overnight, weekly_charter). Companion config.
model ListingModelOption {
  id        String                @id @default(cuid())
  key       String                @unique
  label     String
  sortOrder Int                   @default(0)
  boats     BoatListingModel[]
  pricing   BoatPricing[]
  seasonal  BoatSeasonalPrice[]

  @@map("listing_model_options")
}

/* ========================= Boat brands / models (lookup) ================= */

model BoatBrand {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  category  BoatBrandCategory
  logoUrl   String?
  isActive  Boolean          @default(true)
  source    DataSource       @default(MANUAL)
  createdAt DateTime         @default(now())
  models    BoatModel[]

  @@index([category])
  @@map("boat_brands")
}

model BoatModel {
  id        String     @id @default(uuid()) @db.Uuid
  brandId   String     @db.Uuid
  brand     BoatBrand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  isActive  Boolean    @default(true)
  source    DataSource @default(MANUAL)
  createdAt DateTime   @default(now())

  @@unique([brandId, name])
  @@map("boat_models")
}

model BrandModelRequest {
  id             String                  @id @default(uuid()) @db.Uuid
  captainId      String                  @db.Uuid
  captain        Profile                 @relation(fields: [captainId], references: [id], onDelete: Cascade)
  requestedBrand String
  requestedModel String?
  status         BrandModelRequestStatus @default(PENDING)
  createdAt      DateTime                @default(now())

  @@index([captainId])
  @@index([status])
  @@map("brand_model_requests")
}

model CabinConfiguration {
  id        String     @id @default(uuid()) @db.Uuid
  boatId    String
  boat      Boat       @relation(fields: [boatId], references: [id], onDelete: Cascade)
  cabinType CabinType
  wcType    WcType?
  quantity  Int        @default(1)
  createdAt DateTime   @default(now())

  @@index([boatId])
  @@map("cabin_configurations")
}

/* ============================ Boats (operational) ===================== */

model Boat {
  id      String  @id @default(cuid())
  ownerId String  @db.Uuid
  owner   Profile @relation("BoatOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Step 1 — Listing model & approval
  approvalType ApprovalType @default(MANUAL)

  // Step 2 — Boat type & technical features
  boatTypeKey String?
  boatType    BoatTypeOption? @relation(fields: [boatTypeKey], references: [key])
  engineType  EngineType?

  // Step 4 — Description & rules
  title          String?
  description    String?
  rulesText      String?
  checkInNotes   String?
  checkOutNotes  String?
  structuredRules Json?

  // Status & onboarding progress
  status            BoatStatus       @default(DRAFT)
  currentStep       OnboardingStep   @default(LISTING_MODEL)
  activeStep        OnboardingStep   @default(LISTING_MODEL)
  completedSteps    OnboardingStep[] @default([])
  isReadyForReview  Boolean          @default(false)
  lastSavedAt       DateTime?

  // Review workflow
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?  @db.Uuid
  reviewedBy      Profile? @relation("BoatReviewer", fields: [reviewedById], references: [id])
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations to onboarding sub-resources
  listingModels BoatListingModel[]
  featureValues BoatFeatureValue[]
  amenities     BoatAmenity[]
  photos        BoatPhoto[]
  pricing       BoatPricing[]
  seasonalPrices BoatSeasonalPrice[]
  extras        BoatExtra[]
  documents     BoatDocument[]
  cabinConfigurations CabinConfiguration[]

  // Legacy marketplace relations (phase 0)
  reservations  Reservation[]
  reviews       Review[]

  @@index([ownerId])
  @@index([status])
  @@index([boatTypeKey])
  @@map("boats")
}

/* ============================ Experiences ============================= */

model Experience {
  id                    String                @id @default(uuid()) @db.Uuid
  captainId             String                @db.Uuid
  captain               Profile               @relation(fields: [captainId], references: [id], onDelete: Cascade)
  status                ExperienceStatus      @default(DRAFT)
  currentStep           ExperienceStep        @default(CATEGORY)
  completedSteps        ExperienceStep[]      @default([])

  category              ExperienceCategory?
  title                 String                @default("")
  shortDescription      String                @default("")
  fullDescription       String                @default("")
  highlights            String[]              @default([])
  keywords              String[]              @default([])

  included              String[]              @default([])
  notIncluded           String[]              @default([])
  notAllowed            String[]              @default([])
  knowBeforeYouGo       String[]              @default([])
  emergencyContactPhone String?

  durationMinutes       Int                   @default(60)
  meetingPoint          String                @default("")
  meetingPointLat       Float?
  meetingPointLng       Float?
  meetingTime           String                @default("")
  languages             String[]              @default([])
  minParticipants       Int                   @default(1)
  maxParticipants       Int                   @default(10)
  requiredEquipment     String[]              @default([])
  accessibilityInfo     String?

  basePrice             Decimal               @default(0) @db.Decimal(10, 2)
  currency              String                @default("EUR")
  pricingType           ExperiencePricingType @default(PER_PERSON)
  childDiscountPercent  Int?

  cancellationPolicy     CancellationPolicyType @default(FREE_24H)
  cancellationPolicyText String?

  coverPhotoUrl         String                @default("")
  photoUrls             String[]              @default([])
  videoUrl              String?

  reviewNote            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([captainId])
  @@index([status])
  @@index([category])
  @@map("experiences")
}

/// Which listing models a boat supports (hourly + daily, etc.).
model BoatListingModel {
  boatId          String
  boat            Boat               @relation(fields: [boatId], references: [id], onDelete: Cascade)
  listingModelKey String
  listingModel    ListingModelOption @relation(fields: [listingModelKey], references: [key])

  @@id([boatId, listingModelKey])
  @@map("boat_listing_models")
}

/// Per-boat value for a technical feature (e.g. engine_count = "2").
model BoatFeatureValue {
  id         String            @id @default(cuid())
  boatId     String
  boat       Boat              @relation(fields: [boatId], references: [id], onDelete: Cascade)
  featureKey String
  feature    FeatureDefinition @relation(fields: [featureKey], references: [key])
  value      String?

  @@unique([boatId, featureKey])
  @@index([boatId])
  @@map("boat_feature_values")
}

/// Amenities a boat has, with optional extra-charge configuration.
model BoatAmenity {
  boatId     String
  boat       Boat     @relation(fields: [boatId], references: [id], onDelete: Cascade)
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  isIncluded Boolean  @default(true)
  isExtra    Boolean  @default(false)
  extraPrice Decimal? @db.Decimal(10, 2)
  currency   String?

  @@id([boatId, amenityId])
  @@index([boatId])
  @@map("boat_amenities")
}

model BoatPhoto {
  id          String   @id @default(cuid())
  boatId      String
  boat        Boat     @relation(fields: [boatId], references: [id], onDelete: Cascade)
  storagePath String
  publicUrl   String?
  sortOrder   Int      @default(0)
  isCover     Boolean  @default(false)
  altText     String?
  createdAt   DateTime @default(now())

  @@index([boatId])
  @@map("boat_photos")
}

/// Base price per listing model. Extensible for seasonal/custom pricing.
model BoatPricing {
  id              String             @id @default(cuid())
  boatId          String
  boat            Boat               @relation(fields: [boatId], references: [id], onDelete: Cascade)
  listingModelKey String
  listingModel    ListingModelOption @relation(fields: [listingModelKey], references: [key])
  price           Decimal            @db.Decimal(10, 2)
  currency        String             @default("EUR")

  @@unique([boatId, listingModelKey])
  @@index([boatId])
  @@map("boat_pricing")
}

/// Future-ready seasonal / date-range price overrides.
model BoatSeasonalPrice {
  id              String             @id @default(cuid())
  boatId          String
  boat            Boat               @relation(fields: [boatId], references: [id], onDelete: Cascade)
  listingModelKey String
  listingModel    ListingModelOption @relation(fields: [listingModelKey], references: [key])
  startDate       DateTime
  endDate         DateTime
  price           Decimal            @db.Decimal(10, 2)
  currency        String             @default("EUR")

  @@index([boatId])
  @@map("boat_seasonal_prices")
}

/// Captain-defined extra services.
model BoatExtra {
  id          String           @id @default(cuid())
  boatId      String
  boat        Boat             @relation(fields: [boatId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal          @db.Decimal(10, 2)
  currency    String           @default("EUR")
  pricingType ExtraPricingType @default(PER_BOOKING)
  createdAt   DateTime         @default(now())

  @@index([boatId])
  @@map("boat_extras")
}

model BoatDocument {
  id              String         @id @default(cuid())
  boatId          String
  boat            Boat           @relation(fields: [boatId], references: [id], onDelete: Cascade)
  documentTypeKey String
  documentType    DocumentType   @relation(fields: [documentTypeKey], references: [key])
  storagePath     String
  publicUrl       String?
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?
  reviewedById    String?        @db.Uuid
  reviewedBy      Profile?       @relation("DocumentReviewer", fields: [reviewedById], references: [id])

  @@index([boatId])
  @@index([status])
  @@map("boat_documents")
}

/* ===================== Legacy marketplace (phase 0) ==================== */

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  avatarUrl    String?
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  captainProfile CaptainProfile?
  reservations   Reservation[]   @relation("CustomerReservations")
  reviews        Review[]
  customerConversations Conversation[] @relation("ConversationCustomer")

  @@index([role])
}

model CaptainProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  businessName    String?
  verified        Boolean  @default(false)
  payoutAccountId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payouts Payout[]
}

model Reservation {
  id         String            @id @default(cuid())
  boatId     String
  boat       Boat              @relation(fields: [boatId], references: [id])
  customerId String
  customer   User              @relation("CustomerReservations", fields: [customerId], references: [id])
  startDate  DateTime
  endDate    DateTime
  guests     Int
  totalPrice Decimal           @db.Decimal(10, 2)
  status     ReservationStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  payment Payment?
  payout  Payout?
  review  Review?
  conversation Conversation?

  @@index([boatId])
  @@index([customerId])
  @@index([status])
}

model Payment {
  id                    String        @id @default(cuid())
  reservationId         String        @unique
  reservation           Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  amount                Decimal       @db.Decimal(10, 2)
  paidAmount            Decimal       @default(0) @db.Decimal(10, 2)
  status                PaymentStatus @default(PENDING)
  method                String?
  stripePaymentIntentId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([status])
}

model Payout {
  id               String         @id @default(cuid())
  captainId        String
  captain          CaptainProfile @relation(fields: [captainId], references: [id])
  reservationId    String         @unique
  reservation      Reservation    @relation(fields: [reservationId], references: [id])
  amount           Decimal        @db.Decimal(10, 2)
  status           PayoutStatus   @default(PENDING)
  stripeTransferId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([captainId])
  @@index([status])
}

model Conversation {
  id            String   @id @default(cuid())
  reservationId String   @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  customerId    String
  customer      User     @relation("ConversationCustomer", fields: [customerId], references: [id])
  captainId     String   @db.Uuid
  captain       Profile  @relation("ConversationCaptain", fields: [captainId], references: [id])
  messages      Message[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([captainId])
  @@map("conversations")
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderType     MessageSenderType
  body           String
  attachmentUrl  String?
  readAt         DateTime?
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Review {
  id            String      @id @default(cuid())
  boatId        String
  boat          Boat        @relation(fields: [boatId], references: [id], onDelete: Cascade)
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  customerId    String
  customer      User        @relation(fields: [customerId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())

  @@index([boatId])
}
